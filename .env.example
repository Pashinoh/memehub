APP_NAME=memehub
APP_VERSION=1.3.6
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://localhost
APP_LOCALE=id

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=memehub
DB_USERNAME=
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

VITE_APP_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: ffmpeg binary path (Linux example)
FFMPEG_BIN=/usr/bin/ffmpeg

# Optional: ffmpeg binary path (Windows example)
# FFMPEG_BINARY=C:\\ffmpeg\\bin\\ffmpeg.exe
FFMPEG_BINARY=

# Media processing defaults tuned for low-resource servers (~2GB RAM)
MEDIA_UPLOAD_MAX_KB=30720
MEDIA_IMAGE_WEBP_QUALITY=74
MEDIA_VIDEO_COMPRESS_MIN_KB=6144
MEDIA_VIDEO_SCALE_MAX_WIDTH=960
MEDIA_VIDEO_PRESET=superfast
MEDIA_VIDEO_CRF=30
MEDIA_VIDEO_MAXRATE=900k
MEDIA_VIDEO_BUFSIZE=1800k
MEDIA_VIDEO_THREADS=1
MEDIA_VIDEO_AUDIO_BITRATE=80k
MEDIA_VIDEO_TIMEOUT_SECONDS=90
MEDIA_GIF_COMPRESS_MIN_KB=4096
MEDIA_GIF_FPS=10
MEDIA_GIF_SCALE_MAX_WIDTH=720
MEDIA_GIF_THREADS=1
MEDIA_GIF_TIMEOUT_SECONDS=60
BLOCKED_ACCOUNT_NAMES=admin,administrator,root,superadmin,owner,support,staff,moderator,mod,system
ADMIN_EMAILS=sidescomberan123@gmail.com
